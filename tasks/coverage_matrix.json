      "F": { "name": "Cross-Modal Behavior", "name_zh": "跨模态行为", "measures": "How the agent handles non-text files — visual-heavy vs text-only vs balanced", "key_signals": ["file_read on image/media files", "cross_file_reference between media and text", "chart/image descriptions in output"] }
