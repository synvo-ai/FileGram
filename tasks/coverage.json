{
  "description": "Coverage matrix mapping observable_attributes to tasks. Each attribute shows which tasks observe it and through what behavioral signal.",
  "attribute_to_task_mapping": {
    "reading_strategy": {
      "definition": "How the user explores and navigates files: sequential deep reading vs. keyword search vs. breadth-first browsing",
      "profile_dimension": "A (Consumption Pattern)",
      "observed_by": [
        {"task": "T-01", "signal": "file_open sequence, file_browse events, trigger sources"},
        {"task": "T-02", "signal": "file_open order, coverage of different file types including non-text"},
        {"task": "T-05", "signal": "whether files are read before organizing vs. organized by filename only"},
        {"task": "T-06", "signal": "which sources read first, reading depth per source, cross-file reference patterns"},
        {"task": "T-07", "signal": "file access order, coverage ratio, sampling vs. exhaustive reading"}
      ],
      "task_count": 5
    },
    "output_detail": {
      "definition": "Level of detail and completeness in produced content: word count, data citations, structural depth",
      "profile_dimension": "B (Production Style)",
      "observed_by": [
        {"task": "T-01", "signal": "output file length, number of headings, whether specific numbers cited"},
        {"task": "T-02", "signal": "output granularity, individual case detail vs. high-level themes"},
        {"task": "T-03", "signal": "total content volume per file, depth of index"},
        {"task": "T-04", "signal": "content completeness, word count, section depth"},
        {"task": "T-06", "signal": "report length, number of data points cited"},
        {"task": "T-07", "signal": "profile comprehensiveness, number of dimensions covered"},
        {"task": "T-08", "signal": "report length, number of concrete metrics"},
        {"task": "T-09", "signal": "resulting document length relative to original"}
      ],
      "task_count": 8
    },
    "output_structure": {
      "definition": "How output content is organized: flat narrative vs. hierarchical sections vs. bullet lists vs. tables",
      "profile_dimension": "B (Production Style)",
      "observed_by": [
        {"task": "T-01", "signal": "output organization style in summary file"},
        {"task": "T-02", "signal": "output organization (narrative vs. per-case vs. timeline)"},
        {"task": "T-03", "signal": "content organization across files"},
        {"task": "T-04", "signal": "document structure choice"},
        {"task": "T-06", "signal": "report organization style"},
        {"task": "T-07", "signal": "profile organization format"},
        {"task": "T-08", "signal": "report format choice"},
        {"task": "T-09", "signal": "structural changes made during revision"}
      ],
      "task_count": 8
    },
    "tone": {
      "definition": "Writing register and formality level: formal/professional vs. casual/conversational vs. neutral",
      "profile_dimension": "B (Production Style)",
      "observed_by": [
        {"task": "T-01", "signal": "language register in output file"},
        {"task": "T-02", "signal": "formality level in case summary"},
        {"task": "T-03", "signal": "writing style in knowledge base content"},
        {"task": "T-04", "signal": "writing register in meeting notes and emails"},
        {"task": "T-06", "signal": "writing register in research report"},
        {"task": "T-07", "signal": "writing style in personal profile"}
      ],
      "task_count": 6
    },
    "directory_style": {
      "definition": "Directory structure preferences: flat vs. nested by topic vs. by file type vs. evolving",
      "profile_dimension": "C (Organization Preference)",
      "observed_by": [
        {"task": "T-03", "signal": "dir_create events, directory depth, nesting pattern"},
        {"task": "T-04", "signal": "whether outputs are organized into subdirectories"},
        {"task": "T-05", "signal": "resulting directory structure after reorganization"},
        {"task": "T-08", "signal": "whether output includes supporting file structure"},
        {"task": "T-10", "signal": "whether existing structure is preserved or reorganized"}
      ],
      "task_count": 5
    },
    "naming": {
      "definition": "File naming conventions: descriptive_long vs. short_abbreviation vs. date_prefix vs. category_prefix",
      "profile_dimension": "C (Organization Preference)",
      "observed_by": [
        {"task": "T-03", "signal": "file naming pattern in created knowledge base files"},
        {"task": "T-04", "signal": "output file naming pattern"},
        {"task": "T-05", "signal": "whether files are renamed and how"},
        {"task": "T-08", "signal": "output filename convention chosen"},
        {"task": "T-10", "signal": "whether new files follow existing naming convention"}
      ],
      "task_count": 5
    },
    "edit_strategy": {
      "definition": "How existing content is modified: incremental small edits vs. large bulk rewrites; edit frequency and amplitude",
      "profile_dimension": "D (Iteration Strategy)",
      "observed_by": [
        {"task": "T-09", "signal": "file_edit event count, lines changed per edit, number of passes"},
        {"task": "T-10", "signal": "how existing files are modified: incremental additions vs. section rewrites"}
      ],
      "task_count": 2
    },
    "version_strategy": {
      "definition": "How old versions are handled: keep history (backup/archive) vs. overwrite vs. archive",
      "profile_dimension": "C/D (Organization + Iteration)",
      "observed_by": [
        {"task": "T-05", "signal": "handling of apparent duplicates or old versions during reorganization"},
        {"task": "T-09", "signal": "whether original file is preserved before editing"},
        {"task": "T-10", "signal": "whether old content is backed up before modification"}
      ],
      "task_count": 3
    },
    "cross_modal_behavior": {
      "definition": "Whether the user creates or references visual/tabular supplementary materials vs. pure text",
      "profile_dimension": "F (Cross-Modal Behavior)",
      "observed_by": [
        {"task": "T-04", "signal": "whether supplementary tracking documents created beyond main output"},
        {"task": "T-06", "signal": "whether data is presented in tables/lists vs. pure prose"},
        {"task": "T-08", "signal": "whether supplementary data files or charts are created alongside report"}
      ],
      "task_count": 3
    }
  },
  "task_to_dimension_mapping": {
    "T-01": {"type": "understand",   "dimensions": ["A", "B"],      "attributes": ["reading_strategy", "output_detail", "output_structure", "tone"]},
