    "T-05": {"type": "organize",     "dimensions": ["A", "C"],      "attributes": ["reading_strategy", "directory_style", "naming", "version_strategy"]},
    "T-06": {"type": "synthesize",   "dimensions": ["A", "B", "F"], "attributes": ["reading_strategy", "output_detail", "output_structure", "tone", "cross_modal_behavior"]},
