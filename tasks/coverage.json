    "T-08": {"type": "create",       "dimensions": ["B", "C", "F"], "attributes": ["output_detail", "output_structure", "directory_style", "naming", "cross_modal_behavior"]},
    "T-09": {"type": "iterate",      "dimensions": ["D", "B"],      "attributes": ["edit_strategy", "version_strategy", "output_detail", "output_structure"]},
    "T-10": {"type": "maintain",     "dimensions": ["D", "C", "E"], "attributes": ["edit_strategy", "directory_style", "version_strategy", "naming"]}
