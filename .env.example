# ============================================================
# FileGram Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.

# LLM Provider: google | anthropic | azure_openai
FILEGRAMENGINE_LLM_PROVIDER=anthropic

# ============================================================
# Google Gemini (required for evaluation)
# ============================================================
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# Anthropic Claude (optional, for trajectory generation)
# ============================================================
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ============================================================
# Azure OpenAI (optional, alternative LLM backend)
# ============================================================
# Get your key from: https://portal.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ============================================================
# Cohere (required for embedding in baseline methods)
# ============================================================
# Get your key from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key-here
