# ============================================================
# FileGram Configuration
# ============================================================
# Copy this file to .env and fill in your API keys
# 复制此文件为 .env 并填入你的 API Key
# ============================================================

# ============================================================
# LLM Provider Selection (选择默认使用的 LLM 提供商)
# ============================================================
# Options: azure_openai | anthropic | openai
SYNVOCODE_LLM_PROVIDER=azure_openai

# ============================================================
# Azure OpenAI Configuration (Azure OpenAI 配置)
# ============================================================
# Get your key from: https://portal.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ============================================================
# Anthropic Claude Configuration (Anthropic Claude 配置)
# ============================================================
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# Model options: claude-sonnet-4-20250514, claude-opus-4-20250514, 
#                claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_TEMPERATURE=1.0
# Enable extended thinking (需要支持的模型)
ANTHROPIC_ENABLE_THINKING=false
ANTHROPIC_THINKING_BUDGET_TOKENS=10000

# ============================================================
# OpenAI Configuration (OpenAI 配置)
# ============================================================
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
# Model options: gpt-4o, gpt-4o-mini, gpt-4-turbo, o1, o1-mini, o3-mini
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=8192
OPENAI_TEMPERATURE=1.0

# ============================================================
# Skill System (技能系统配置)
# ============================================================
# Disable skill system entirely
SYNVOCODE_DISABLE_SKILLS=false
# Custom skill paths (colon-separated)
SYNVOCODE_SKILL_PATHS=/path/to/custom/skills:/another/path
# Disable Claude Code compatible skills
SYNVOCODE_DISABLE_CLAUDE_SKILLS=false

# ============================================================
# MCP (Model Context Protocol) Configuration
# ============================================================
# Disable MCP entirely
SYNVOCODE_DISABLE_MCP=false
# Path to custom mcp.json config file
SYNVOCODE_MCP_CONFIG=
# MCP server connection timeout (seconds)
SYNVOCODE_MCP_TIMEOUT=30.0

# ============================================================
# Cohere Configuration (Cohere Embedding API)
# ============================================================
# Get your key from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key-here

# ============================================================
# Web Search (Exa API for websearch/codesearch tools)
# ============================================================
# Get your key from: https://exa.ai/
EXA_API_KEY=your-exa-api-key-here
